{% extends 'partials/base.html.twig' %}

{% block content %}

<section class="beer-catalog">
    {{ dump(page.children) }}
    <div class="container">

        <h1>{{ page.title }}</h1>

        <div class="beer-grid" id="beer-grid">
            {% for beer in page.children.visible %}
            <a href="{{ beer.url }}" class="beer-card">

            {% set poster = beer.media[beer.header.poster] %}
              {% if poster %}
                <div class="beer-poster-wrapper">
                  <img src="{{ poster.cropResize(300, 200).url }}"
                  alt="{{ beer.title }}"
                  class="beer-poster">
               </div>
           {% endif %}
 
            <div class="beer-info">
             <h2>{{ beer.title }}</h2>
                 <p class="beer-style">{{ beer.header.style }}</p>
                 <p class="beer-style">{{ beer.header.abv }}</p>
            </div>

            </a>
           {% endfor %}
        </div>

    </div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
    			const grid = document.getElementById('beer-grid');
    			const cards = [...grid.children];
    			cards.sort(() => Math.random() - 0.5);
    			cards.forEach(card => grid.appendChild(card));
		});
	</script>
</section>

{% endblock %}
